{
  "name": "vietjewelers",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "data:process": "tsx scripts/process-csv.ts",
    "dev": "concurrently \"vite --port=3000 --host=0.0.0.0\" \"tsx watch server/index.ts\"",
    "dev:frontend": "vite --port=3000 --host=0.0.0.0",
    "dev:server": "tsx watch server/index.ts",
    "sitemap": "tsx scripts/generate-sitemap.ts",
    "build": "npm run data:process && npm run sitemap && vite build",
    "start": "node --import tsx server/index.ts",
    "seed": "tsx server/scripts/seed.ts",
    "create-admin": "tsx server/scripts/create-admin.ts",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "fuse.js": "^7.1.0",
    "i18next": "^25.8.18",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-helmet-async": "^3.0.0",
    "react-i18next": "^16.5.8",
    "react-router": "^7.13.1",
    "swiper": "^12.1.2",
    "vite": "^6.2.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.8.0",
    "concurrently": "^9.2.1",
    "connect-sqlite3": "^0.9.16",
    "cors": "^2.8.6",
    "csv-parse": "^6.1.0",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "multer": "^2.1.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
