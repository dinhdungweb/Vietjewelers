{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": ".",
    "resolveJsonModule": true,
    "declaration": true,
    "isolatedModules": true,
    "paths": {
      "@shared/*": ["../src/types/*"]
    }
  },
  "include": ["./**/*.ts"],
  "exclude": ["dist", "node_modules", "uploads", "data"]
}
